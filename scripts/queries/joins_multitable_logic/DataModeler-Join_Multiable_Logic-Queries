-- Query 1: Calculates total revenue generated by each product category across all countries

SELECT
    cat.category_name,
    r.country_name,
    SUM(li.net_amount) AS total_revenue
FROM fact_order_line_items li
INNER JOIN dim_products p
    ON li.product_id = p.product_id
INNER JOIN dim_categories cat
    ON p.category_id = cat.category_id
INNER JOIN fact_sales_orders so
    ON li.order_id = so.order_id
INNER JOIN dim_customers c
    ON so.customer_id = c.customer_id
INNER JOIN dim_regions r
    ON c.region_id = r.region_id
GROUP BY
    cat.category_name,
    r.country_name
ORDER BY
    total_revenue DESC;


-- Query 2: Identifies customers with high geographic activity based on total spending

SELECT
    c.customer_id,
    c.customer_code,
    r.country_name,
    SUM(li.net_amount) AS total_spent
FROM fact_sales_orders so
INNER JOIN fact_order_line_items li
    ON so.order_id = li.order_id
INNER JOIN dim_customers c
    ON so.customer_id = c.customer_id
INNER JOIN dim_regions r
    ON c.region_id = r.region_id
GROUP BY
    c.customer_id,
    c.customer_code,
    r.country_name
HAVING SUM(li.net_amount) > 10000
ORDER BY total_spent DESC;


