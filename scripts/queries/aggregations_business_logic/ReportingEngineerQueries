--Query 1 – Average Discount % per Category


SELECT
    cat.category_name,
    AVG(li.discount * 100.0) AS avg_discount_percent
FROM fact_order_line_items li
JOIN dim_products p 
    ON li.product_id = p.product_id
JOIN dim_categories cat 
    ON p.category_id = cat.category_id
GROUP BY cat.category_name
ORDER BY avg_discount_percent DESC;


--Query 2 – Sales Growth per Country (Year over Year)


SELECT
    r.country_name,
    d.year,
    SUM(li.net_amount) AS total_revenue,
    LAG(SUM(li.net_amount)) OVER (
        PARTITION BY r.country_name
        ORDER BY d.year
    ) AS previous_year_revenue,
    SUM(li.net_amount) - LAG(SUM(li.net_amount)) OVER (
        PARTITION BY r.country_name
        ORDER BY d.year
    ) AS revenue_growth
FROM fact_order_line_items li
JOIN fact_sales_orders so 
    ON li.order_id = so.order_id
JOIN dim_customers c 
    ON so.customer_id = c.customer_id
JOIN dim_regions r 
    ON c.region_id = r.region_id
JOIN dim_date d 
    ON li.date_id = d.date_id
GROUP BY r.country_name, d.year;